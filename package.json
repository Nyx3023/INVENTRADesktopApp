{
  "name": "inventory-management-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/index.js",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "electron:start": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win nsis",
    "setup-barcodes": "node scripts/add-test-barcodes.js",
    "build:portable": "node scripts/build-portable.js",
    "build:installer": "node scripts/build-installer.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "adm-zip": "^0.5.16",
    "all": "^0.0.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "chart.js": "^4.4.9",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^5.1.0",
    "firebase": "^11.8.1",
    "form-data": "^4.0.3",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "react": "^19.1.0",
    "react-barcode-reader": "^0.0.2",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.1",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "usb": "^2.17.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "pkg": "^5.8.1",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.inventra.pos.offline",
    "productName": "INVENTRA",
    "files": [
      "dist/**/*",
      "server/**/*",
      "database/**/*",
      "scripts/**/*",
      "public/**/*",
      "uploads/**/*",
      "package.json",
      "node_modules/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "node_modules/usb/**",
      "node_modules/escpos-usb/**",
      "node_modules/@serialport/**"
    ],
    "directories": {
      "output": "release"
    },
    "npmRebuild": true,
    "buildDependenciesFromSource": true,
    "win": {
      "icon": "src/assets/jbologo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "INVENTRA-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
